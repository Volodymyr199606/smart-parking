# Smart Parking Mobile App — Environment Variables
# Copy this file to .env and fill in your Supabase credentials.
# Get these from: Supabase Dashboard → Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — map view (EAS dev build only)
# EXPO_PUBLIC_ENABLE_MAP=false
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Optional — city data preview UI (defaults off)
# EXPO_PUBLIC_ENABLE_CITY_DATA_PREVIEW=false
