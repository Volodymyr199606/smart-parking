# Smart Parking Mobile — copy to apps/mobile/.env
# Required for auth, parking list, favorites, reports, and analytics.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — city data preview in Settings (default off; no MVP behavior change)
EXPO_PUBLIC_ENABLE_CITY_DATA_PREVIEW=false

# Optional — native map (EAS dev build only; Expo Go uses list view)
# EXPO_PUBLIC_ENABLE_MAP=true
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
