# Smart Parking — Environment Variables
#
# This file documents ALL environment variables used across the monorepo.
# Each app has its own .env file — see the specific .env.example in each app folder.
#
# DO NOT put real secrets in this file or commit .env files to git.

# ─── apps/mobile ─────────────────────────────────────────────────────────────
# Copy to: apps/mobile/.env
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── apps/web (future) ───────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
