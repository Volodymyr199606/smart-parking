# Smart Parking — Environment Variables
#
# This file documents ALL environment variables used across the monorepo.
# Each app has its own .env file — see the per-app .env.example files.
#
# DO NOT put real secrets in this file or commit .env files to git.

# ─── apps/mobile ─────────────────────────────────────────────────────────────
# Copy to: apps/mobile/.env
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── apps/web (marketing site + waitlist) ────────────────────────────────────
# Copy to: apps/web/.env.local (preferred) or apps/web/.env
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── City data ingestion (scripts/ingest-sf-parking-data.ts) ───────────────
# Copy to: .env at repo root (never commit). Use service role — not the anon key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: cap rows per dataset (default script batch is 100 unless --full)
# INGEST_LIMIT=100

# ─── City data verification (scripts/check-city-parking-data.ts) ──────────
# Read-only; uses anon key (same as mobile). Loads apps/mobile/.env if present.
# SUPABASE_ANON_KEY=your-anon-key-here
